# Disable directory browsing
Options -Indexes

# Custom error pages (these will be served by Apache only if Node fails)
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html

# Optional: Force HTTPS (if Apache handles SSL termination)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]
